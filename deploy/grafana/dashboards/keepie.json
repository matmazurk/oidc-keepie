{
  "uid": "keepie-overview",
  "title": "Keepie Overview",
  "tags": ["keepie"],
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Jobs Scheduled (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(keepie_jobs_scheduled_total[1m])",
          "legendFormat": "scheduled/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Jobs Consumed (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(keepie_jobs_consumed_total[1m])",
          "legendFormat": "consumed/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Jobs Processed (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(keepie_jobs_processed_total[1m])",
          "legendFormat": "processed/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Jobs Pipeline (totals)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "keepie_jobs_scheduled_total",
          "legendFormat": "Scheduled",
          "refId": "A"
        },
        {
          "expr": "keepie_jobs_consumed_total",
          "legendFormat": "Consumed",
          "refId": "B"
        },
        {
          "expr": "keepie_jobs_processed_total",
          "legendFormat": "Processed",
          "refId": "C"
        },
        {
          "expr": "keepie_jobs_failed_total",
          "legendFormat": "Failed",
          "refId": "D"
        },
        {
          "expr": "keepie_jobs_rescheduled_total",
          "legendFormat": "Rescheduled",
          "refId": "E"
        }
      ]
    },
    {
      "id": 5,
      "title": "Errors (rate/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(keepie_jobs_failed_total[1m])",
          "legendFormat": "failed",
          "refId": "A"
        },
        {
          "expr": "rate(keepie_jobs_rescheduled_total[1m])",
          "legendFormat": "rescheduled",
          "refId": "B"
        },
        {
          "expr": "rate(keepie_jobs_unmarshal_errors_total[1m])",
          "legendFormat": "unmarshal errors",
          "refId": "C"
        },
        {
          "expr": "rate(keepie_consumer_offset_commit_errors_total[1m])",
          "legendFormat": "offset commit errors",
          "refId": "D"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(keepie_http_requests_total[1m])",
          "legendFormat": "requests/s",
          "refId": "A"
        },
        {
          "expr": "rate(keepie_http_invalid_bodies_total[1m])",
          "legendFormat": "invalid bodies/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Job Processing Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(keepie_jobs_processing_duration_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(keepie_jobs_processing_duration_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(keepie_jobs_processing_duration_seconds_bucket[1m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "Time in Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(keepie_jobs_time_in_queue_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(keepie_jobs_time_in_queue_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(keepie_jobs_time_in_queue_seconds_bucket[1m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "title": "HTTP Handler Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(keepie_http_duration_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(keepie_http_duration_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(keepie_http_duration_seconds_bucket[1m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "title": "Traces",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceqlSearch",
          "serviceName": "keepie",
          "limit": 20,
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{container=~\".*/keepie.*\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
